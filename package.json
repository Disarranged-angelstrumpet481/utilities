{
  "sideEffects"       : false,
  "name"              : "@obvia/utilities",
  "description"       : "Foundational utilities and constants that empower clarity and developer experience.",
  "keywords"          : ["utility", "utilities", "helpers", "constants", "functions", "type-safe", "modular", "lightweight", "shared", "semantic", "obvia", "react", "nuxt", "nextjs", "vue"],
  "license"           : "MIT",
  "homepage"          : "https://obvia.studio/",
  "version"           : "0.0.4",

  "author"            : {
    "name"  : "Selçuk Çukur",
    "email" : "hello@selcukcukur.me",
    "url"   : "https://selcukcukur.me"
  },

  "bugs"              : {
    "email" : "security@obvia.studio",
    "url"   : "https://github.com/obvialabs/obvia/issues"
  },

  "scripts"           : {
    "build"     : "tsup",
    "dev"       : "tsup --watch",
    "test"      : "vitest",
    "coverage"  : "pnpm test --coverage",
    "clean"     : "rimraf node_modules dist .turbo"
  },

  "main"              : "./dist/core/index.mjs",
  "module"            : "./dist/core/index.mjs",
  "types"             : "./dist/core/index.d.mts",

  "dependencies"      : {
    "class-variance-authority"  : "^0.7.1",
    "clsx"                      : "^2.1.1",
    "tailwind-merge"            : "^3.5.0"
  },
  "devDependencies"   : {
    "@obvia/presets"            : "^0.0.2",
    "@types/node"               : "^25.5.0",
    "@types/react"              : "^19.2.4",
    "typescript"                : "^5.9.3",
    "tsup"                      : "^8.5.1",
    "vitest"                    : "^4.0.18",
    "@vitest/coverage-v8"       : "^4.0.18",
    "@vitest/ui"                : "^4.0.18",
    "rimraf"                    : "^6.1.3"
  },
  "peerDependencies"  : {
    "react"                     : "^19",
    "react-dom"                 : "^19",
    "next"                      : "^16",
    "vue"                       : "^3",
    "nuxt"                      : "^4"
  },
  "peerDependenciesMeta": {
    "react"                     : {
      "optional"  : true
    },
    "react-dom"                 : {
      "optional"  : true
    },
    "next"                      : {
      "optional"  : true
    },
    "vue"                       : {
      "optional"  : true
    },
    "nuxt"                      : {
      "optional"  : true
    }
  },

  "exports"           : {
    "."       : {
      "import"  : "./dist/core/index.mjs",
      "require" : "./dist/core/index.mjs",
      "types"   : "./dist/core/index.d.mts"
    },
    "./vue"   : {
      "import"  : "./dist/vue/index.mjs",
      "require" : "./dist/vue/index.mjs",
      "types"   : "./dist/vue/index.d.mts"
    },
    "./react" : {
      "import"  : "./dist/react/index.mjs",
      "require" : "./dist/react/index.mjs",
      "types"   : "./dist/react/index.d.mts"
    },
    "./next"  : {
      "import"  : "./dist/next/index.mjs",
      "require" : "./dist/next/index.mjs",
      "types"   : "./dist/next/index.d.mts"
    },
    "./nuxt"  : {
      "import"  : "./dist/nuxt/index.mjs",
      "require" : "./dist/nuxt/index.mjs",
      "types"   : "./dist/nuxt/index.d.mts"
    }
  },
  "files"             : ["dist", "readme.md", "license.md"],

  "publishConfig"     : {
    "access"  : "public"
  },
  "publisher"         : {
    "type" : "github",
    "user" : "obvialabs",
    "repo" : "utilities"
  },
  "repository"        : {
    "type"      : "git",
    "url"       : "git+https://github.com/obvialabs/utilities.git"
  }
}
